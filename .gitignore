# OS / editor
.DS_Store
Thumbs.db

# Python build/runtime artifacts (F-5: never track generated files)
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Windows security zone metadata (from downloads)
*:Zone.Identifier
*Zone.Identifier

# LangGraph state DB (SqliteSaver — Phase 1+)
state.db
state.db-shm
state.db-wal

# Git worktrees created by carve_worktree (T4.2a)
worktrees/

# Phase 4 (T4.1): audit log from PreToolUse hooks (contains tool call history)
# Path: logs/audit.jsonl (configurable via SDD_AUDIT_LOG env var)
logs/

# Phase 6 (T6.3): local observability store (total_cost_usd + token records)
# Default path is ~/.sdd-runs/ (outside project, never tracked).
# In-project fallbacks (if SDD_OBS_STORE points into project root):
sdd-runs/
.sdd-runs/
