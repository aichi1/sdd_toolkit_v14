{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,

    "excludedCommands": ["git"],
    "allowUnsandboxedCommands": false,

    "network": {
      "allowedDomains": ["*"]
    }
  },

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Bash(pytest)",
      "Bash(pytest *)",
      "Bash(python -m pytest)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m pytest)",
      "Bash(python3 -m pytest *)",

      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run build)",
      "Bash(npm run build *)",

      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote -v)",

      "Bash(mkdir -p ~/.sdd-knowledge/*)",
      "Bash(cp * ~/.sdd-knowledge/*)",
      "Bash(cp outputs/* ~/.sdd-knowledge/*)",
      "Bash(python3 scripts/*.py *)",

      "Edit(~/.sdd-knowledge/**)",
      "Write(~/.sdd-knowledge/**)"
    ],

    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git remote *)",

      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(python -m pip install *)",
      "Bash(python3 -m pip install *)",
      "Bash(npm install *)",
      "Bash(npm ci *)"
    ],

    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.envrc)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",

      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",

      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(.envrc)",
      "Edit(./secrets/**)",
      "Edit(./config/credentials.json)",

      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(mkfs.*)",

      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(nc *)",
      "Bash(netcat *)",
      "Bash(ftp *)",
      "Bash(telnet *)",

      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(podman *)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git remote set-url *)",
      "Bash(git config --global *)",
      "Bash(git gc *)",
      "Bash(git clean -fd*)",
      "Bash(git filter-repo *)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(outputs/**)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/post-phase-complete.sh\" \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write(outputs/**)|Edit(outputs/**)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-docs-exist.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/remind-finalize.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-info.py\""
          }
        ]
      }
    ]
  }
}
